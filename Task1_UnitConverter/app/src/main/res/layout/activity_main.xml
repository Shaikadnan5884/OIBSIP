<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/toolbar_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="#FFFFFF" />

    <!-- Top Display Area -->
    <LinearLayout
        android:id="@+id/displayContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- From Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#2C2C2C"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <Spinner
                        android:id="@+id/fromSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#41AB41"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/fromValueText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="#41AB41"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- To Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#2C2C2C"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <Spinner
                        android:id="@+id/toSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#41AB41"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:id="@+id/toValueText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0"
                        android:textColor="#41AB41"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Swap Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnSwap"
            android:layout_width="64dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:cardBackgroundColor="#2C2C2C"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="Swap"
                android:src="@android:drawable/stat_notify_sync"
                app:tint="#41AB41" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Number Pad Section -->
    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:columnCount="4"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/displayContainer">

        <!-- Row 1 -->
        <Button style="@style/KeypadButton"
            android:id="@+id/btn7"
            android:text="7" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn8"
            android:text="8" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn9"
            android:text="9" />
        <Button style="@style/KeypadTallButton"
            android:id="@+id/btnAC"
            android:layout_rowSpan="2"
            android:text="AC" />

        <!-- Row 2 -->
        <Button style="@style/KeypadButton"
            android:id="@+id/btn4"
            android:text="4" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn5"
            android:text="5" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn6"
            android:text="6" />

        <!-- Row 3 -->
        <Button style="@style/KeypadButton"
            android:id="@+id/btn1"
            android:text="1" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn2"
            android:text="2" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn3"
            android:text="3" />
        <Button style="@style/KeypadTallButton"
            android:id="@+id/btnDelete"
            android:layout_rowSpan="2"
            android:text="DEL" />

        <!-- Row 4 -->
        <Button style="@style/KeypadButton"
            android:id="@+id/btn00"
            android:text="00" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btn0"
            android:text="0" />
        <Button style="@style/KeypadButton"
            android:id="@+id/btnDot"
            android:text="." />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>