<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CreateQuizActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Quiz"
            android:textColor="@color/quiz_primary_green"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/quizTitleEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Quiz Title"
            android:inputType="text" />

        <EditText
            android:id="@+id/quizCodeEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Access Code (e.g. MATH101)"
            android:inputType="textCapCharacters" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select Category:"
            android:textColor="@color/quiz_medium_green" />

        <Spinner
            android:id="@+id/categorySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="@android:color/darker_gray" />

        <TextView
            android:id="@+id/questionCountTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Question 1"
            android:textColor="@color/quiz_dark_green"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/newQuestionEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Enter Question" />

        <EditText
            android:id="@+id/newOption1EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Option 1" />

        <EditText
            android:id="@+id/newOption2EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Option 2" />

        <EditText
            android:id="@+id/newOption3EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Option 3" />

        <EditText
            android:id="@+id/newOption4EditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Option 4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select Correct Option:"
            android:textColor="@color/quiz_medium_green" />

        <RadioGroup
            android:id="@+id/correctOptionRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/correctOption1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1" />

            <RadioButton
                android:id="@+id/correctOption2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2" />

            <RadioButton
                android:id="@+id/correctOption3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3" />

            <RadioButton
                android:id="@+id/correctOption4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4" />
        </RadioGroup>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/addQuestionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_gradient"
            android:text="Add This Question"
            android:textColor="@color/white" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/saveQuizButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/button_gradient"
            android:text="Finish and Save Quiz"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>